# direnv: auto-start the demo terminal when you cd into this folder.
#
# Enable once (per direnv's security model):
#   direnv allow
#
# It's idempotent — if the servers are already up it does nothing, and it never
# pops a browser (that's `make start`). Stop them with `make stop`.
if has make; then
  make up >/dev/null 2>&1 || true
  echo "demo terminal → http://localhost:8088   (make stop to stop)"
fi
